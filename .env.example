# ============================================================================
# Environment Variables Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to GitHub (it contains sensitive data)
# ============================================================================

# ============================================================================
# CLOUDINARY CONFIGURATION
# ============================================================================
# Get these from: https://cloudinary.com/console/settings/api-keys
# 1. Sign up at https://cloudinary.com
# 2. Go to Settings → API Keys
# 3. Copy the values below

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
# Get these from: https://console.firebase.google.com
# 1. Create a Firebase project
# 2. Go to Project Settings → General
# 3. Copy the values below

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
# Generate a random secret key for Flask sessions
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=your_random_secret_key_here

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Port to run the Flask development server on
# Default: 5000

PORT=5000

# ============================================================================
# EXAMPLE VALUES (DO NOT USE THESE)
# ============================================================================
# CLOUDINARY_CLOUD_NAME=dj9jarlpi
# CLOUDINARY_API_KEY=921654219599862
# CLOUDINARY_API_SECRET=Hy4i2V2nhwt5DPuufM0LEXbxixE
# FIREBASE_API_KEY=AIzaSyAKxg2KIt5JXPodg9O-qtmz_cKEJsZE-5w
# FIREBASE_PROJECT_ID=cloud-storage-app-cec2c
# SECRET_KEY=abcdef1234567890abcdef1234567890
# PORT=5000

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Open .env file in your editor
# 3. Replace all "your_*" values with actual credentials
# 4. Save the file
# 5. Run: python app.py
#
# For detailed setup instructions, see:
# - QUICK_START.md
# - FIREBASE_COMPLETE_SETUP.md
# ============================================================================
